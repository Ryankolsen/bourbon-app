# Supabase connection (required)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin emails — comma-separated list of email addresses that should have
# admin access in the app. Matching is case-insensitive and whitespace around
# commas is ignored. Example: ryankolsen@gmail.com,other@example.com
EXPO_PUBLIC_ADMIN_EMAILS=
